# ── Supabase / PostgREST ──
# PostgREST listens on port 54321 inside docker-compose.
SUPABASE_URL=http://localhost:54321

# The anon JWT used by supabase-py for every request.
# It must be signed with PGRST_JWT_SECRET below and carry {"role": "anon"}.
# Generate one at https://jwt.io using:
#   Header : {"alg": "HS256", "typ": "JWT"}
#   Payload: {"role": "anon"}
#   Secret : <same value as PGRST_JWT_SECRET below>
SUPABASE_KEY=

# ── PostgREST / PostgreSQL ──
# Must match PGRST_JWT_SECRET in docker-compose.yml.
# Use any long random string (32+ chars). Keep this secret.
PGRST_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Password for the local PostgreSQL 'postgres' superuser.
POSTGRES_PASSWORD=postgres

# ── Gemini ──
GEMINI_API_KEY=
# Optional: override the default model
# GEMINI_MODEL=models/gemini-2.0-flash

# ── SMTP (email notifications) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=

# ── Output ──
# Local directory where compiled .docx / .txt files are saved.
OUTPUT_DIR=./output

# ── Google Sheets (only needed when importing from a Sheet) ──
# Path to a service account credentials JSON file, or the raw JSON string.
GOOGLE_SHEETS_CREDENTIALS_JSON=
